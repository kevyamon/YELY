{
  "expo": {
    "name": "Yély",
    "slug": "YELY",
    "version": "1.2.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon-hd.png",
    "scheme": "yely",
    "userInterfaceStyle": "automatic",
    "owner": "kevyllc",
    "splash": {
      "image": "./assets/images/splash-center.png",
      "resizeMode": "contain",
      "backgroundColor": "#D4AF37"
    },
    "updates": {
      "url": "https://u.expo.dev/be0e185d-b91e-41bf-9e18-91923cf7deb5",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yely.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.yely.app",
      "versionCode": 3,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "name": "Yély",
      "shortName": "Yély",
      "favicon": "./assets/images/favicon.png",
      "display": "standalone",
      "scope": "/",
      "startUrl": "/",
      "backgroundColor": "#D4AF37",
      "themeColor": "#D4AF37",
      "orientation": "portrait",
      "bundler": "metro",
      "splash": {
        "image": "./assets/images/splash-center.png",
        "resizeMode": "contain",
        "backgroundColor": "#D4AF37"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-center.png",
          "resizeMode": "contain",
          "backgroundColor": "#D4AF37"
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Yely a besoin de votre position pour vous attribuer des courses.",
          "locationAlwaysPermission": "Yely a besoin de votre position pour que clients puissent suivre votre approche.",
          "locationWhenInUsePermission": "Yely a besoin de votre position pour identifier les trajets.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#D4AF37"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "yelyllc",
          "project": "yely-app"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "be0e185d-b91e-41bf-9e18-91923cf7deb5"
      }
    }
  }
}